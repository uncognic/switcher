<Window x:Class="switcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switcher"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#CC1a1a1a"
        Topmost="True"
        ShowInTaskbar="False"
        Visibility="Hidden"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <ItemsControl x:Name="WindowList" Margin="4" MaxWidth="660">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Width="100" Margin="4" Padding="8"
                BorderThickness="2"
                Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BorderBrush" Value="DodgerBlue"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Width="36" Height="36" Source="{Binding Icon}"
                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Title}" Foreground="#e0e0e0"
                           FontSize="11" FontFamily="Segoe UI"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center" MaxWidth="72" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</Window>